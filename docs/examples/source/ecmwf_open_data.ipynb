            "source": [
                "## Retrieving ECMWF open data"
            ]
        },
        {
            "cell_type": "raw",
            "id": "e32794dd-b06c-4274-8125-e1b00e01245e",
            "metadata": {
                "editable": true,
                "raw_mimetype": "text/restructuredtext",
                "slideshow": {
                    "slide_type": ""
                },
                "tags": []
            },
            "source": [
                "The :ref:`ecmwf-open-data <data-sources-eod>` source provides access to the `ECMWF open data <https://www.ecmwf.int/en/forecasts/datasets/open-data>`_ ."
            ]
        },
        {
            "cell_type": "code",
            "execution_count": 1,
            "id": "bcc2e1e1-a048-40c5-b830-b8aa601f97ac",
            "metadata": {},
            "outputs": [],
            "source": [
                "import earthkit.data as ekd\n",
                "\n",
                "ds = ekd.from_source(\n",
                "    \"ecmwf-open-data\",\n",
                "    request=dict(param=[\"t\", \"gh\"], levelist=\"500\", step=[0, 24, 48]),\n",
                ").to_fieldlist()"
            ]
        },
